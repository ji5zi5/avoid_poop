NODE_ENV=development
PORT=3001
COOKIE_SECRET=replace-with-a-long-random-secret
APP_ORIGIN=http://localhost:5173
TRUST_PROXY=false
LOG_ENABLED=true
LOG_LEVEL=debug
DB_PROVIDER=sqlite
DB_PATH=server/data/avoid-poop.sqlite
RATE_LIMIT_AUTH_MAX=12
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_WRITES_MAX=40
RATE_LIMIT_WRITES_WINDOW_MS=60000
RATE_LIMIT_WS_MAX=40
RATE_LIMIT_WS_WINDOW_MS=60000

# Future production target:
# DB_PROVIDER=postgres
# DATABASE_URL=postgres://user:password@host:5432/avoid_poop
# Recommended production overrides:
# NODE_ENV=production
# APP_ORIGIN=https://your-domain.example
# TRUST_PROXY=true
# LOG_LEVEL=info
